{
  "name": "multi-tenant-saas-boilerplate",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo run db:generate --filter=@saas/database",
    "db:migrate": "turbo run db:migrate --filter=@saas/database",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@bull-board/api": "^6.10.2",
    "@bull-board/express": "^6.10.2",
    "@types/node": "^22.13.9",
    "bullmq": "^5.47.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.2",
    "@saas/eslint-config": "*"
  },
  "overrides": {
    "ioredis": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "esbuild",
    "turbo",
    "tsx"
  ]
}
