# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://saas:saaspassword@localhost:5432/saas

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-32-chars-min
JWT_EXPIRES_IN=7d

# ─── Admin API ────────────────────────────────────────────────────────────────
# Used to authenticate admin routes (X-Admin-Secret header)
ADMIN_SECRET=change-me-admin-secret

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Webhooks ─────────────────────────────────────────────────────────────────
WEBHOOK_SIGNATURE_SECRET=change-me-webhook-secret
WEBHOOK_TIMEOUT_MS=10000

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info
PROMETHEUS_ENABLED=true
